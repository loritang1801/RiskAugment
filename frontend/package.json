{
  "name": "risk-control-platform-frontend",
  "version": "1.0.0",
  "description": "Risk Control Decision Enhancement Platform - Frontend",
  "type": "module",
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js",
    "build": "node ./node_modules/vite/bin/vite.js build",
    "preview": "node ./node_modules/vite/bin/vite.js preview",
    "lint": "node ./node_modules/eslint/bin/eslint.js src --ext .vue,.ts --fix --ignore-path .eslintignore",
    "type-check": "node ./node_modules/vue-tsc/bin/vue-tsc.js --noEmit -p tsconfig.json --composite false"
  },
  "dependencies": {
    "@vueuse/core": "^10.4.1",
    "ant-design-vue": "^4.0.6",
    "axios": "^1.5.0",
    "echarts": "^5.4.3",
    "pinia": "^2.1.4",
    "vue": "^3.3.4",
    "vue-router": "^4.2.4"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.7.2",
    "@typescript-eslint/parser": "^6.7.2",
    "@vitejs/plugin-vue": "^4.3.4",
    "@vue/tsconfig": "^0.4.0",
    "eslint": "^8.49.0",
    "eslint-plugin-vue": "^9.17.0",
    "typescript": "~5.2.2",
    "unplugin-vue-components": "^31.0.0",
    "vite": "^4.5.14",
    "vue-tsc": "^1.8.8"
  }
}
