# Database Configuration
# Keep DATABASE_URL aligned with backend dev profile for consistent demo data.
DATABASE_URL=postgresql://risk_control_user:risk_control_password@localhost:5433/risk_control_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=risk_control_db
POSTGRES_USER=risk_control_user
POSTGRES_PASSWORD=risk_control_password

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379

# Java Backend
JAVA_PORT=8080
JAVA_ENV=development

# Python AI Service
FLASK_ENV=development
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=False

# Frontend
FRONTEND_PORT=3000
VITE_API_BASE_URL=http://localhost:8080

# LLM Configuration
LLM_PROVIDER=bigmodel
LLM_MODEL=glm-4.6
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# Prefer provider-specific keys below. LLM_API_KEY is kept as backward-compatible fallback.
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_COMPATIBLE_API_KEY=
ANTHROPIC_API_KEY=your-anthropic-api-key-here
BIGMODEL_API_KEY=your-bigmodel-api-key-here
ZHIPU_API_KEY=
DEEPSEEK_API_KEY=
MINIMAX_API_KEY=
LLM_API_KEY=
LLM_TIMEOUT=30
LLM_MAX_RETRIES=0
LLM_MAX_CONCURRENCY=2
LLM_MIN_INTERVAL_MS=300
LLM_RATE_LIMIT_RETRIES=2
LLM_RATE_LIMIT_BACKOFF_MS=800
LLM_ALLOW_MOCK=false

# AI decision behavior
# llm_only: model is authoritative; no mock rule engine history tool
# hybrid: include rule engine/history tool context
AI_DECISION_MODE=llm_only
AI_FAIL_FAST=true
ANALYZE_TIMEOUT_SECONDS=35
AGENT_SIMILAR_TOP_K=2
AGENT_LLM_TEMPERATURE=0.2
AGENT_LLM_MAX_TOKENS=320
AI_RULE_CALIBRATION_MODE=strict

# Upstream tool integrations (only needed in hybrid mode)
RULE_ENGINE_URL=
RULE_ENGINE_TOKEN=
RULE_ENGINE_TIMEOUT_SECONDS=5
TRANSACTION_HISTORY_URL=
TRANSACTION_HISTORY_TOKEN=
TRANSACTION_HISTORY_TIMEOUT_SECONDS=5
AGENT_TOOL_ALLOW_FALLBACK=false

# Embedding Configuration
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
EMBEDDING_DIMENSION=1024

# RAG Configuration
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.7

# Application
APP_NAME=Risk Control Decision Enhancement Platform
APP_VERSION=1.0.0
SECRET_KEY=your-secret-key-change-in-production
APP_JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
APP_JWT_EXPIRATION_HOURS=8

